{
  "$schema": "https://raw.githubusercontent.com/dotnet/Nerdbank.GitVersioning/main/src/NerdBank.GitVersioning/version.schema.json",
  "version": "2.3",
  "publicReleaseRefSpec": [ 
    "^refs/heads/master$",
    "^refs/tags/v\\d+\\.\\d+\\.\\d+$"
  ],
  "pathFilters": [":/src"],
  "release": {
    "tagName" : "v{version}"
  },
  "nugetPackageVersion": {
    "semVer": 2
  },
  "cloudBuild": {
    "buildNumber": {
      "enabled": true
    }
  }
}