{
  "$schema": "https://raw.githubusercontent.com/dotnet/Nerdbank.GitVersioning/main/src/NerdBank.GitVersioning/version.schema.json",
  "version": "2.2",
  "publicReleaseRefSpec": [ "^refs/heads/master$" ],
  "pathFilters": [":/src"],
  "release": {
    "tagName" : "v{version}"
  },
  "nugetPackageVersion": {
    "semVer": 2
  },
  "cloudBuild": {
    "buildNumber": {
      "enabled": true
    }
  }
}